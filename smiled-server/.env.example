# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://smiled:smiled@localhost:5432/smiled

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Must match BETTER_AUTH_SECRET in smiled-web/.env
# Used by Rust to verify HMAC signatures on session cookies
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=smiled-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── Multi-tenancy ────────────────────────────────────────────────────────────
# "single" for a single-cabinet deployment, "multi" for SaaS
TENANT_MODE=single
# Required only when TENANT_MODE=single
DEFAULT_CABINET_ID=00000000-0000-0000-0000-000000000001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── SMTP (optional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
