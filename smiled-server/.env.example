# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://smiled:smiled@localhost:5432/smiled

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_a_secure_random_string
JWT_EXPIRY_HOURS=24

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=smiled-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── Multi-tenancy ────────────────────────────────────────────────────────────
# "single" for a single-cabinet deployment, "multi" for SaaS
TENANT_MODE=single
# Required only when TENANT_MODE=single
DEFAULT_CABINET_ID=00000000-0000-0000-0000-000000000001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── SMTP (optional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
