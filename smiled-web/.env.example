# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL of the Smiled.IO backend
NUXT_PUBLIC_API_BASE=http://localhost:8080
# Public-facing app URL (used by Better Auth for CORS / trusted origins)
NUXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection for Better Auth (session management)
DATABASE_URL=postgresql://smiled:smiled@localhost:5433/smiled
